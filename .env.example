# ─── Database (TiDB / MySQL) ──────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl=true&sslcert=&sslaccept=strict"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET="change-me-to-at-least-32-chars-random-string"
JWT_EXPIRES_IN="7d"

# ─── MQTT (HiveMQ Cloud) ──────────────────────────────────────
MQTT_HOST="xxxxxxxx.s1.eu.hivemq.cloud"
MQTT_PORT="8883"
MQTT_USERNAME="your-hivemq-username"
MQTT_PASSWORD="your-hivemq-password"
MQTT_BRIDGE_TOKEN="shared-secret-if-using-broker-webhook"

# ─── App ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
MQTT_WORKER_ENABLED="true"
